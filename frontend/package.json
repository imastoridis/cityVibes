{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json --poll 1000",
    "build": "ng build --output-path=./dist/frontend --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run -c vitest.config.ts",
    "serve:ssr:frontend": "node dist/frontend/server/server.mjs",
    "lint": "ng lint",
    "prettier": "prettier --write \"src/**/*.{ts,html,css,scss,js,json}\""
  },
  "private": true,
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.0",
    "@angular/localize": "^21.2.6",
    "@angular/material": "^21.2.5",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.5",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "express": "^5.1.0",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "npm-check-updates": "^20.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/platform": "^2.2.1",
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@analogjs/vitest-angular": "^2.3.1",
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/angular": "^19.0.0",
    "@testing-library/dom": "^10.4.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@vitest/coverage-v8": "^4.0.15",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsonc": "^2.16.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "lightningcss": "^1.32.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.8"
  }
